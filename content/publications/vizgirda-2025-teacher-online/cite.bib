@inproceedings{Vizgirda2025TeacherOnline,
 abstract = {School teachers around the world use online resources in their teaching. The education systems in which teachers work directly impact their freedom to choose, adapt, and use resources in their classes. This, in turn, influences teachers' information interactions involved in lesson planning and resource preparation, but few studies have investigated this relationship. Based on a semi-structured interview and observation study with 15 school teachers working with the Scottish Curriculum for Excellence, a process model is proposed to describe teacher tasks and strategies for finding, using, and sharing educational resources. This study addresses the influence of the education system context and considers implications for design of search systems that support online educational resource search by school teachers. A supplementary open licensed dataset can be found at https://osf.io/a2xs8/.},
 address = {New York, NY, USA},
 author = {Vizgirda, Vidminas and McNeill, Fiona and Robertson, Judy},
 booktitle = {Proceedings of the 2025 ACM SIGIR Conference on Human Information Interaction and Retrieval},
 doi = {10.1145/3698204.3716448},
 isbn = {979-8-4007-1290-6},
 month = {April},
 pages = {81--99},
 publisher = {Association for Computing Machinery},
 series = {CHIIR '25},
 title = {Teacher Online Educational Resource Search in Education System Context},
 urldate = {2025-07-31},
 year = {2025}
}
